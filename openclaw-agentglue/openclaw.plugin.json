{
  "id": "openclaw-agentglue",
  "name": "AgentGlue",
  "version": "0.4.0",
  "description": "Cross-process dedup cache for multi-agent tool calls via SQLite sidecar",
  "configSchema": {
    "type": "object",
    "properties": {
      "host": {
        "type": "string",
        "default": "127.0.0.1",
        "description": "Sidecar host address"
      },
      "port": {
        "type": "integer",
        "default": 8765,
        "description": "Sidecar port"
      },
      "autoStart": {
        "type": "boolean",
        "default": true,
        "description": "Auto-start sidecar on plugin load"
      },
      "maxRestarts": {
        "type": "integer",
        "default": 3,
        "description": "Maximum sidecar restart attempts"
      },
      "restartDelayMs": {
        "type": "integer",
        "default": 2000,
        "description": "Delay between restart attempts (ms)"
      },
      "healthCheckIntervalMs": {
        "type": "integer",
        "default": 30000,
        "description": "Health check interval (ms)"
      },
      "cacheTTL": {
        "type": "number",
        "default": 300,
        "description": "Default cache TTL in seconds for auto-cached tool results"
      },
      "dbPath": {
        "type": "string",
        "default": "",
        "description": "SQLite database path (default: ~/.openclaw/cache/agentglue.db)"
      }
    }
  }
}
